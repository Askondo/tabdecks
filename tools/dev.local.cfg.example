# Machine-specific dev config — copy to tools/dev.local.cfg (gitignored) and adjust.
# KEY=VALUE lines; # starts a comment.

# Chrome executable
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Dedicated dev profile (created if missing) — keeps the extension out of your main profile
PROFILE_DIR=D:\tmp\tabdecks-chrome-profile

# Pages to open on launch (comma-separated). 'tone' expands to the local test-tone page.
START_PAGES=tone,tone
