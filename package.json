{
  "name": "tabdecks",
  "version": "0.1.0",
  "description": "DJ mixer for Chrome tab audio — capture two tabs as decks, mix with EQ, FX, and timeshift transport",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "chrome": "tsx tools/launch_chrome.ts",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@wxt-dev/module-svelte": "^2.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "wxt": "^0.20.0"
  }
}
